{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "videh.co.in",
        "VIDEOH_SLIM_ANDROID": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "apkRelease": {
      "distribution": "internal",
      "prebuildCommand": "npx expo prebuild --platform android --clean",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "videh.co.in",
        "VIDEOH_SLIM_ANDROID": "1",
        "EXPO_ROUTER_APP_ROOT": "app"
      },
      "android": {
        "buildType": "apk"
      },
      "cache": {
        "key": "apk-release-v136-v1063"
      }
    },
    "production": {
      "autoIncrement": true,
      "prebuildCommand": "npx expo prebuild --platform android --clean",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "videh.co.in",
        "VIDEOH_SLIM_ANDROID": "1",
        "EXPO_ROUTER_APP_ROOT": "app"
      },
      "android": {
        "buildType": "app-bundle"
      },
      "cache": {
        "key": "production-v98-webrtc-fix"
      }
    }
  }
}
