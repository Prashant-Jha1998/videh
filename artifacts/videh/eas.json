{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "VIDEOH_SLIM_ANDROID": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "apkRelease": {
      "distribution": "internal",
      "env": {
        "VIDEOH_SLIM_ANDROID": "1"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "VIDEOH_SLIM_ANDROID": "1"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
