{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "videh.co.in",
        "VIDEOH_SLIM_ANDROID": "1",
        "EXPO_PUBLIC_ONESIGNAL_APP_ID": ""
      },
      "android": {
        "buildType": "apk"
      }
    },
    "apkRelease": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_DOMAIN": "videh.co.in",
        "VIDEOH_SLIM_ANDROID": "1",
        "EXPO_PUBLIC_ONESIGNAL_APP_ID": ""
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "videh.co.in",
        "VIDEOH_SLIM_ANDROID": "1",
        "EXPO_PUBLIC_ONESIGNAL_APP_ID": ""
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
