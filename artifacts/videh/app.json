{
  "expo": {
    "name": "Videh",
    "slug": "videh",
    "version": "1.0.13",
    "orientation": "portrait",
    "icon": "./assets/images/videh_icon_foreground.png",
    "scheme": "videh",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/videh_icon_foreground.png",
      "resizeMode": "contain",
      "backgroundColor": "#0B141A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.videh.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Videh needs microphone access for voice calls, Hey Videh assistant, and video calls.",
        "NSSpeechRecognitionUsageDescription": "Videh uses speech recognition for Hey Videh voice assistant commands.",
        "NSCameraUsageDescription": "Videh needs camera access for video calls.",
        "NSContactsUsageDescription": "Videh uses your contacts to find friends who are already on Videh.",
        "NSBluetoothAlwaysUsageDescription": "Videh uses Bluetooth for audio routing during calls.",
        "NSPhotoLibraryAddUsageDescription": "Videh saves videos you download from chat to your photo library.",
        "NSLocationWhenInUseUsageDescription": "Videh needs your location to send current location and live location in chats.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Videh uses your location for live location sharing in chats.",
        "NSSiriUsageDescription": "Videh uses the microphone for Hey Videh voice commands.",
        "UIBackgroundModes": [
          "audio",
          "voip",
          "fetch",
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.videh.app",
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 72,
      "androidStatusBar": {
        "backgroundColor": "#00A884",
        "barStyle": "light-content",
        "translucent": true
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/videh_icon_foreground.png",
        "backgroundColor": "#0B141A"
      },
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE",
        "android.permission.BLUETOOTH",
        "android.permission.BLUETOOTH_ADMIN",
        "android.permission.BLUETOOTH_CONNECT",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_WIFI_STATE",
        "android.permission.CHANGE_NETWORK_STATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MICROPHONE",
        "android.permission.FOREGROUND_SERVICE_PHONE_CALL",
        "android.permission.MANAGE_OWN_CALLS",
        "android.permission.READ_PHONE_NUMBERS",
        "android.permission.BIND_TELECOM_CONNECTION_SERVICE",
        "android.permission.CALL_PHONE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_DOCUMENTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.USE_FULL_SCREEN_INTENT",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/images/videh_icon_foreground.png"
    },
    "notification": {
      "icon": "./assets/images/videh_icon_foreground.png",
      "color": "#00A884"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-contacts",
      [
        "expo-image-picker",
        {
          "cameraPermission": "Videh needs camera access to take photos and record videos in chat.",
          "microphonePermission": "Videh needs microphone access to record videos in chat.",
          "photosPermission": "Allow Videh to access your photos to send images in chat."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow Videh to access your photos to save videos from chat.",
          "savePhotosPermission": "Allow Videh to save videos from chat to your gallery.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/videh_icon_foreground.png",
          "color": "#00A884",
          "defaultChannel": "messages",
          "sounds": [
            "./assets/sounds/msg_default.wav",
            "./assets/sounds/msg_chime.wav",
            "./assets/sounds/msg_soft.wav",
            "./assets/sounds/msg_alert.wav",
            "./assets/sounds/msg_vip.wav",
            "./assets/sounds/msg_romantic.wav",
            "./assets/sounds/msg_business.wav",
            "./assets/sounds/msg_family.wav",
            "./assets/sounds/msg_office.wav",
            "./assets/sounds/msg_nature.wav",
            "./assets/sounds/msg_festival.wav",
            "./assets/sounds/msg_gaming.wav",
            "./assets/sounds/msg_bell.wav",
            "./assets/sounds/msg_ding.wav",
            "./assets/sounds/msg_pop.wav",
            "./assets/sounds/msg_echo.wav",
            "./assets/sounds/msg_piano.wav",
            "./assets/sounds/msg_marimba.wav",
            "./assets/sounds/msg_zen.wav",
            "./assets/sounds/call_default.wav",
            "./assets/sounds/call_modern.wav",
            "./assets/sounds/call_soft.wav",
            "./assets/sounds/call_business.wav",
            "./assets/sounds/call_nature.wav",
            "./assets/sounds/call_musical.wav",
            "./assets/sounds/call_classic.wav",
            "./assets/sounds/call_pulse.wav",
            "./assets/sounds/call_digital.wav",
            "./assets/sounds/call_marimba.wav",
            "./assets/sounds/call_zen.wav",
            "./assets/sounds/call_urgent.wav",
            "./assets/sounds/call_bell.wav",
            "./assets/sounds/incoming_call.wav"
          ]
        }
      ],
      "./plugins/withAndroidAdjustResize.js",
      "./plugins/withIncomingCallAndroid.js",
      "@config-plugins/react-native-callkeep",
      "./plugins/withVidehCallPip.js",
      "./plugins/withVidehPipModule.js",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Videh needs your location to send current location and live location in chats.",
          "locationAlwaysAndWhenInUsePermission": "Videh uses your location for live location sharing in chats.",
          "isAndroidBackgroundLocationEnabled": false
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Videh needs microphone access for Hey Videh voice assistant and calls.",
          "speechRecognitionPermission": "Videh uses speech recognition for Hey Videh voice commands.",
          "androidSpeechServicePackages": [
            "com.google.android.tts",
            "com.google.android.googlequicksearchbox",
            "com.google.android.as",
            "com.samsung.android.bixby.agent",
            "com.microsoft.cognitiveservices.speech.recognition"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "owner": "prashantjha112",
    "extra": {
      "router": {
        "origin": "https://replit.com/"
      },
      "eas": {
        "projectId": "72d49bc8-c465-47d0-ba9d-6aa765d6e315"
      }
    }
  }
}
