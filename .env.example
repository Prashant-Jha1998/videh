# API / Postgres (see project docs for full list)
DATABASE_URL=

# Optional: shared call/signaling state when running 2+ API instances (Upstash/Redis Cloud).
# Single EC2 server can leave empty.
REDIS_URL=
# UPSTASH_REDIS_URL=

# Firebase Cloud Messaging (recommended — production message notifications)
# Firebase Console → Project Settings → Service accounts → Generate new private key
# Paste the full JSON on one line, or set path on the server:
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_PATH=/var/www/videh/firebase-service-account.json

# Admin panel (https://your-host/admin) — set on Render; do not commit real secrets
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# TOTP / Google Authenticator: Base32 secret (min ~8 chars). Add same secret to your app as "Videh Admin".
ADMIN_TOTP_SECRET=

# Razorpay story boosts
# Public key can be exposed to clients. Secret must stay server-side only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
