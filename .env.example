# API / Postgres (see project docs for full list)
DATABASE_URL=

# Admin panel (https://your-host/admin) — set on Render; do not commit real secrets
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_TOTP_SECRET=

# Razorpay story boosts
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: shared call/signaling when running 2+ API instances
REDIS_URL=

# VAPID Web Push — FREE, self-hosted, no Firebase / OneSignal
# Generate: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@videh.co.in
# Same public key in mobile/web build:
# EXPO_PUBLIC_VAPID_PUBLIC_KEY=
