# API / Postgres
DATABASE_URL=

# Admin panel
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
ADMIN_TOTP_SECRET=
# SLA breach alerts (comma-separated) — Resend or SMTP
ADMIN_ALERT_EMAIL=
RESEND_API_KEY=
RESEND_FROM=Videh Admin <noreply@videh.co.in>
# Or webhook (Slack/custom): ADMIN_ALERT_WEBHOOK_URL=

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: 2+ API servers (calls/signaling)
REDIS_URL=

# Firebase Cloud Messaging — same as WhatsApp on Android (recommended)
# Firebase Console → Project Settings → Service accounts → Generate new private key
FIREBASE_SERVICE_ACCOUNT_JSON=
# FIREBASE_SERVICE_ACCOUNT_PATH=/var/www/videh/firebase-service-account.json

# App: download google-services.json from Firebase → artifacts/videh/google-services.json
# EAS: upload FCM key in Expo dashboard (Credentials → Android → FCM V1)

# Optional: Web Push (browser only)
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# EXPO_PUBLIC_VAPID_PUBLIC_KEY=
