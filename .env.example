# API / Postgres (see project docs for full list)
DATABASE_URL=

# Admin panel (https://your-host/admin) — set on Render; do not commit real secrets
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# TOTP / Google Authenticator: Base32 secret (min ~8 chars). Add same secret to your app as "Videh Admin".
ADMIN_TOTP_SECRET=

# Razorpay story boosts
# Public key can be exposed to clients. Secret must stay server-side only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Optional: shared call/signaling state when running 2+ API instances (Upstash/Redis Cloud).
# Single EC2 server can leave empty.
REDIS_URL=
# UPSTASH_REDIS_URL=

# OneSignal — FREE push (no Firebase). https://onesignal.com
# App Settings → Keys & IDs: App ID + REST API Key
ONESIGNAL_APP_ID=
ONESIGNAL_REST_API_KEY=
# Same App ID in mobile build (EAS / .env):
# EXPO_PUBLIC_ONESIGNAL_APP_ID=
