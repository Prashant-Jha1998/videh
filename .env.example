# API / Postgres (see project docs for full list)
DATABASE_URL=

# Admin panel (https://your-host/admin) — set on Render; do not commit real secrets
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
# TOTP / Google Authenticator: Base32 secret (min ~8 chars). Add same secret to your app as "Videh Admin".
ADMIN_TOTP_SECRET=

# Razorpay story boosts
# Public key can be exposed to clients. Secret must stay server-side only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
